# CockroachDB connection string
DATABASE_URL=postgresql://user:password@host:26257/defaultdb?sslmode=require

# JWT secret (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=30d

# Stable email encryption key. Keep this fixed across deploys/environments
# that need to decrypt existing user emails.
EMAIL_ENCRYPTION_KEY=change-me-to-a-long-random-email-encryption-secret

# API server port
PORT=3001

# Local frontend URL used for API CORS during development.
CLIENT_URL=http://localhost:5173

# Production user-facing URLs. Email, invite, reset, and lobby links should
# point to app.thepokerplanner.com, never the Render service URL.
APP_URL=https://app.thepokerplanner.com
PUBLIC_URL=https://thepokerplanner.com

# Email (Resend preferred; SMTP is fallback)
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=ThePokerPlanner <hello@thepokerplanner.com>

# Web Push notifications
# Generate with: npm run generate:vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:support@thepokerplanner.com

# Protected automation/job endpoint secret. Schedule POST /api/jobs/daily-reminders
# for 8:00 AM America/New_York with x-job-secret: this value.
JOB_SECRET=change-me-to-a-long-random-job-secret
DAILY_REMINDER_JOB_URL=https://app.thepokerplanner.com/api/jobs/daily-reminders

# AI announcer and hand analysis lab
OPENAI_API_KEY=sk_your_openai_key
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
DEFAULT_AI_CREDITS=25

# Optional SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
