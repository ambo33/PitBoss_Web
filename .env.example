# CockroachDB connection string
DATABASE_URL=postgresql://user:password@host:26257/defaultdb?sslmode=require

# JWT secret (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret

# API server port
PORT=3001

# Frontend URL (for email links and CORS). Optional on Render because
# RENDER_EXTERNAL_URL is used automatically when CLIENT_URL is not set.
CLIENT_URL=http://localhost:5173

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=PitBoss <your@gmail.com>
