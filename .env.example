# CockroachDB connection string
DATABASE_URL=postgresql://user:password@host:26257/defaultdb?sslmode=require

# JWT secret (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=30d

# API server port
PORT=3001

# Frontend URL (for email links and CORS). Optional on Render because
# RENDER_EXTERNAL_URL is used automatically when CLIENT_URL is not set.
CLIENT_URL=http://localhost:5173

# Email (Resend preferred; SMTP is fallback)
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=PokerPlanner.bet <hello@pokerplanner.bet>

# Optional SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
